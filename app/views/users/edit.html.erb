<% provide(:title, t("users.edit.title")) %>
<% provide(:button_text, t("users.edit.submit")) %>

<h1 class="mb-4"><%= t("users.edit.heading") %></h1>

<div class="row">
  <div class="col-md-6 offset-md-3">

    <%= render "form" %>

    <div class="d-flex align-items-center gap-3 mt-4">
      <div class="gravatar_edit">
        <%= gravatar_for @user %>
      </div>
      <a href="https://gravatar.com/emails" target="_blank" rel="noopener">
        <%= t("helpers.links.change") %>
      </a>
    </div>

  </div>
</div>