<li class="d-flex align-items-center gap-2">
    <%= gravatar_for user, size: 50 %>
    <%= link_to user.name, user %>
    <% if current_user.admin? && !current_user?(user) %>
    | <%= link_to t("helpers.links.delete"),
                    user_path(user),
                    data: {
                    turbo_method: :delete,
                    turbo_confirm: t("helpers.confirms.delete")
                    } %>
    <% end %>
</li> 
