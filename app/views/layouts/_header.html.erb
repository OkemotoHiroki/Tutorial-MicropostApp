<header class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
  <div class="container">

    <%= link_to t("navigation.brand"), root_path, class: "navbar-brand" %>

    <!-- ハンバーガーボタン -->
    <button class="navbar-toggler" type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- collapse必須 -->
    <div class="collapse navbar-collapse" id="navbarNav">

      <ul class="navbar-nav ms-auto">

        <li class="nav-item">
          <%= link_to t("navigation.home"), root_path, class: "nav-link" %>
        </li>

        <li class="nav-item">
          <%= link_to t("navigation.help"), help_path, class: "nav-link" %>
        </li>

        <% if logged_in? %>

          <li class="nav-item">
            <%= link_to t("navigation.users"), users_path, class: "nav-link" %>
          </li>

          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle"
               href="#"
               role="button"
               data-bs-toggle="dropdown">
              <%= t("navigation.account") %>
            </a>

            <ul class="dropdown-menu dropdown-menu-end">

              <li>
                <%= link_to t("navigation.profile"), current_user, class: "dropdown-item" %>
              </li>

              <li>
                <%= link_to t("navigation.settings"), edit_user_path(current_user), class: "dropdown-item" %>
              </li>

              <li><hr class="dropdown-divider"></li>

              <li>
                <%= link_to t("navigation.log_out"), logout_path,
                  data: { turbo_method: :delete },
                  class: "dropdown-item" %>
              </li>

            </ul>
          </li>

        <% else %>

          <li class="nav-item">
            <%= link_to t("navigation.log_in"), login_path, class: "nav-link" %>
          </li>

        <% end %>

      </ul>
    </div>
  </div>
</header>
