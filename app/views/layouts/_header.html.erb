    <header class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
      <div class="container">
        <%= link_to "sample_app", root_path, id: "logo", class: "navbar-brand" %>
        <nav>
          <ul class="nav navbar-nav navbar-right">
            <li><%= link_to "Home", root_path ,class: "nav-link" %></li>
            <li><%= link_to "Help", help_path ,class: "nav-link" %></li>
            <% if logged_in? %>
              <li><%= link_to "Users", users_path,class: "nav-link" %></li>

              <li class="nav-item dropdown">
                <a href="#" class="nav-link dropdown-toggle" role="button" data-bs-toggle="dropdown">
                  Account <b class="caret"></b>
                </a>

                <ul class="dropdown-menu">
                  <li>
                    <%= link_to "Profile", current_user, class: "dropdown-item" %>
                  </li>

                  <li>
                    <%= link_to "Settings", edit_user_path(current_user), class: "dropdown-item" %>
                  </li>

                  <li><hr class="dropdown-divider"></li>

                  <li>
                    <%= link_to "Log out", logout_path, data: { turbo_method: :delete }, class: "dropdown-item" %>
                  </li>
                </ul>
              </li>
            <% else %>
              <li><%= link_to "Log in", login_path,class: "nav-link" %></li>
            <% end %>
          </ul>
        </nav>
      </div>
    </header>