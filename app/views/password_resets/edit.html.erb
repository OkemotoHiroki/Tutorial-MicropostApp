<% provide(:title, t("password_resets.edit.title")) %>
<h1><%= t("password_resets.edit.title") %></h1>

<div class="row justify-content-center">
    <div class="col-md-6">
    <%= form_with model: @user, url: password_reset_path(params[:id]),local: true do |f| %>

    <%= render 'shared/error_messages', object: f.object %>

      <%= hidden_field_tag :email, @user.email %>

      <div class="mb-3">
        <%= f.label :password, class: "form-label" %><%= label_hint(f, :password) %>
        <%= f.password_field :password, class: 'form-control', placeholder: true %>
      </div>

      <div class="mb-3">
        <%= f.label :password_confirmation, class: "form-label" %><%= label_hint(f, :password_confirmation) %>
        <%= f.password_field :password_confirmation, class: 'form-control', placeholder: true %>
      </div>

      <div class="d-grid">
        <%= f.submit t("password_resets.edit.submit"), class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
