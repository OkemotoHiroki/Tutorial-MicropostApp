<% provide(:title, t("sessions.new.title")) %>

<h1><%= t("sessions.new.title") %></h1>

<div class="row justify-content-center">
    <div class="col-md-6">

        <%= form_with scope: :session, url: login_path, local: true do |f| %>

            <div class="mb-3">
                <%= f.label :email, class: "form-label" %>
                <%= f.email_field :email, class: "form-control", autocomplete: "email" %>
            </div>

            <div class="mb-3">
                <%= f.label :password, class: "form-label" %>
                <%= link_to t("helpers.links.forgot_password"), new_password_reset_path %>
                <%= f.password_field :password, class: "form-control", autocomplete: "current-password" %>
            </div>

            <div class="form-check">
                <%= f.check_box :remember_me, class: "form-check-input" %>
                <%= f.label :remember_me, t("sessions.new.remember_me"), class: "form-check-label" %>
            </div>

            <div class="d-grid">
                <%= f.submit t("sessions.new.submit"), class: "btn btn-primary" %>
            </div>
        <% end %>

        <div class="mt-3 text-center">
            <p>
                <%= t("sessions.new.new_user") %>
                <%= link_to t("helpers.links.signup_now"), signup_path %>
            </p>
        </div>

  
    </div>
</div>
