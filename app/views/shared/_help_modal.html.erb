<div class="modal fade" id="helpModal" tabindex="-1" aria-labelledby="helpModalLabel"
     aria-hidden="true" data-controller="help-modal">
  <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="helpModalLabel"><%= help_title %></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"
                aria-label="<%= t("help.close") %>"></button>
      </div>
      <div class="modal-body">
        <%= render help_partial_path %>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
          <%= t("help.close") %>
        </button>
      </div>
    </div>
  </div>
</div>
